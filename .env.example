# ── 0G Compute (OpenAI-compatible AI router) ──────────────────────────────
# These are read server-side in /api routes. AI never sees plaintext beyond
# the single inference request the user explicitly triggers.
AI_BASE_URL=https://router-api.0g.ai/v1
AI_API_KEY=
AI_MODEL=

# ── 0G Chain / Storage (public, safe to expose to the browser) ────────────
NEXT_PUBLIC_ZG_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
NEXT_PUBLIC_ZG_CHAIN_ID=16602

# 0G-KV node used to READ the decentralized record index in the browser.
NEXT_PUBLIC_ZG_KV_NODE_URL=https://rpc-storage-testnet-turbo.0g.ai
# Flow contract used by the KV Batcher when WRITING the index.
NEXT_PUBLIC_ZG_FLOW_CONTRACT=0x0460aA47b41a66694c0a73f667a1b795A5ED3556

# Public app URL (used for emergency-card short links / share links).
NEXT_PUBLIC_APP_URL=http://localhost:3000
