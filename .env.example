# WalletConnect / Web3Modal project id (public -- safe to expose to the browser).
# Create one at https://cloud.reown.com (formerly WalletConnect Cloud).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- 0G Compute (AI) -- server-side only, never exposed to the browser ---
# API key for the OpenAI-compatible 0G Compute inference router.
# Without it, AI document extraction and chat fail (the API throws
# "AI_API_KEY is not set").
AI_API_KEY=

# Base URL for the OpenAI-compatible endpoint. Defaults to the 0G router when
# unset. Override only if you use a different gateway.
AI_BASE_URL=https://router-api.0g.ai/v1

# Model id served by 0G Compute (required, no default).
AI_MODEL=
